# Supply an immutable, trusted ROCm/PyTorch image reference (preferably a digest)
# with: docker build -f Dockerfile.hold-gpu --build-arg BASE_IMAGE=repo/image@sha256:... .
ARG BASE_IMAGE
FROM ${BASE_IMAGE}

WORKDIR /work

ENV PYTHONUNBUFFERED=1

COPY scripts/hold_gpu.py /usr/local/bin/hold_gpu.py
RUN chmod +x /usr/local/bin/hold_gpu.py

ENTRYPOINT ["python3", "/usr/local/bin/hold_gpu.py"]
CMD ["--gpus", "0", "--mem-mb", "256", "--duration", "60", "--matrix", "512", "--sleep", "0.2"]
