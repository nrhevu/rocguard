# Default-deny the build context so repository metadata, local state, binaries,
# and secrets cannot be sent to the Docker daemon.
*

!Dockerfile.web
!go.mod
!go.sum

!cmd/
!cmd/gpuardian/
!cmd/gpuardian/*.go

!internal/
!internal/**/
!internal/**/*.go

!web/
!web/ui/
!web/ui/package.json
!web/ui/package-lock.json
!web/ui/index.html
!web/ui/src/
!web/ui/src/**
!web/ui/public/
!web/ui/public/**
